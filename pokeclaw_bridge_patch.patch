+    // ==================== External AI Agent API ====================
+
+    /**
+     * POST /api/task
+     * Body: {"task": "给张三发微信：下午开会", "mode": "task|chat"}
+     * 
+     * Accepts task/chat requests from external AI agents (like sandbox AI).
+     * Executes the same way as ExternalAutomation intents.
+     */
+    private fun handlePostTask(session: IHTTPSession): Response {
+        val files = mutableMapOf<String, String>()
+        session.parseBody(files)
+        val body = files["postData"] ?: ""
+
+        val json = try {
+            gson.fromJson(body, JsonObject::class.java)
+        } catch (e: Exception) {
+            return corsResponse(
+                newFixedLengthResponse(
+                    Response.Status.BAD_REQUEST, MIME_JSON,
+                    """{"code":-1,"message":"invalid json"}"""
+                )
+            )
+        }
+
+        val task = json.get("task")?.asString
+        if (task.isNullOrBlank()) {
+            return corsResponse(
+                newFixedLengthResponse(
+                    Response.Status.BAD_REQUEST, MIME_JSON,
+                    """{"code":-1,"message":"missing or empty 'task' field"}"""
+                )
+            )
+        }
+
+        // Check external automation enabled
+        if (!KVUtils.isExternalAutomationEnabled()) {
+            return corsResponse(
+                newFixedLengthResponse(
+                    Response.Status.FORBIDDEN, MIME_JSON,
+                    """{"code":-2,"message":"External Automation is disabled in PokeClaw Settings"}"""
+                )
+            )
+        }
+
+        // Check no task is running
+        if (appViewModel.isTaskRunning()) {
+            return corsResponse(
+                newFixedLengthResponse(
+                    Response.Status.CONFLICT, MIME_JSON,
+                    """{"code":-3,"message":"Another task is already running"}"""
+                )
+            )
+        }
+
+        val mode = json.get("mode")?.asString ?: "task"
+        XLog.i(TAG, "API task accepted ($mode): ${task.take(120)}")
+
+        // Execute via existing automation infrastructure
+        io.agents.pokeclaw.automation.ExternalAutomationEntrypoint.executeDirect(
+            context = context,
+            text = task,
+            mode = mode
+        )
+
+        val result = JsonObject().apply {
+            addProperty("code", 0)
+            addProperty("message", "Task accepted")
+            addProperty("mode", mode)
+        }
+        return corsResponse(newFixedLengthResponse(Response.Status.OK, MIME_JSON, result.toString()))
+    }
